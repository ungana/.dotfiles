{
  "$schema": "https://opencode.ai/config.json",
  "model": "llama-main/Mellum2-12B-A2.5B-Instruct-Q4_K_M.gguf",
  "small_model": "llama-small/qwen2.5-coder-1.5b",
  
  "provider": {
    "llama-main": {
      "name": "Llama Main (Mellum2)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "none",
        "supportsStructuredOutputs": true
      },
      "models": {
        "Mellum2-12B-A2.5B-Instruct-Q4_K_M.gguf": {
          "name": "JetBrains Mellum2",
          "contextWindow": 32768,
          "maxOutputTokens": 1024,
          "tool_call": true,
          "options": {
            "strictJsonSchema": true
          }
        }
      }
    },
    "llama-small": {
      "name": "Llama Small (Qwen 1.5B)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:8081/v1",
        "apiKey": "none"
      },
      "models": {
        "qwen2.5-coder-1.5b": {
          "name": "Qwen 2.5 Coder 1.5B",
          "contextWindow": 2048,
          "maxOutputTokens": 512
        }
      }
    }
  },
  
  "compaction": {
    "threshold": 0.85,
    "strategy": "truncate",
    "preserveSystemPrompt": true
  },

  "agent": {
    "build": {
      "mode": "primary",
      "permission": {
        "bash": "ask",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "write": "allow"
      }
    }
  },

  "mcp": {
    "context-mode": {
      "type": "local",
      "command": ["context-mode"]
    }
  },

  "plugin": ["context-mode"]
}

