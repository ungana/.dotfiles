{
  "$schema": "https://opencode.ai/config.json",
  "model": "llama-local/Mellum2-12B-A2.5B-Instruct-Q4_K_M.gguf",
  "small_model": "llama-local/Mellum2-12B-A2.5B-Instruct-Q4_K_M.gguf",
  
  "provider": {
    "llama-local": {
      "name": "Llama.cpp",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "apiKey": "none",
        "supportsStructuredOutputs": true
      },
      "models": {
        "Mellum2-12B-A2.5B-Instruct-Q4_K_M.gguf": {
          "name": "Mellum2-12B-A2.5B-Instruct-Q4_K_M.gguf",
          "contextWindow": 32768,
          "maxOutputTokens": 4096,
          "tool_call": true,
          "options": {
            "strictJsonSchema": true
          }
        }
      }
    }
  },
  
  "compaction": {
    "threshold": 0.85,
    "strategy": "truncate",
    "preserveSystemPrompt": true
  },

  "agent": {
    "build": {
      "mode": "primary",
      "permission": {
        "bash": "ask",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "read": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "write": "allow"
      }
    }
  }
}
